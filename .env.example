# Application Configuration
APP_NAME="AI Presentation Generator"
APP_VERSION="1.0.0"
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Settings (comma-separated list for production)
ALLOWED_ORIGINS=*

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.md

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
VLLM_API_BASE=http://localhost:8000/v1

# Database Configuration (optional)
DATABASE_URL=postgresql://user:password@localhost/presentation_db
# DATABASE_URL=sqlite:///./presentation.db

# Security Settings (optional)
SECRET_KEY=your_super_secret_key_here_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging Configuration
LOG_LEVEL=INFO

# Cache Settings (optional)
REDIS_URL=redis://localhost:6379/0

# File Storage (optional - for production)
UPLOAD_DIR=uploads
STATIC_DIR=app/static