# Application Configuration
APP_NAME="AI Presentation Generator"
APP_VERSION="2.0.0"
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS Settings (comma-separated list for production)
ALLOWED_ORIGINS=*

# File Upload Settings
MAX_FILE_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=.pdf,.docx,.txt,.md

# ── LLM Provider Configuration ─────────────────
# Supported: openai, google, vllm
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
VLLM_API_BASE=http://localhost:8001/v1

# Pipeline tuning temperatures
ANALYSIS_TEMPERATURE=0.4
OUTLINE_TEMPERATURE=0.5
SLIDE_TEMPERATURE=0.7

# ── Redis (state + caching) ────────────────────
USE_REDIS=false
REDIS_URL=redis://localhost:6379/0

# ── Image Generation ───────────────────────────
# Supported: none, replicate, stability, dalle
IMAGE_PROVIDER=none
IMAGE_API_KEY=your_image_api_key_here
IMAGE_API_BASE=
IMAGE_DEFAULT_MODEL=flux-1-quick
IMAGE_DEFAULT_STYLE="Modern, clean, presentation-friendly"
IMAGE_WIDTH=1024
IMAGE_HEIGHT=768

# ── Pipeline Settings ──────────────────────────
MAX_PARALLEL_SLIDES=10
MAX_RETRIES=2
RETRY_BACKOFF_BASE=1.0
MAX_DOCUMENT_CHARS=12000

# ── Token Budgets (per textAmount setting) ─────
TOKEN_BUDGET_MINIMAL=80
TOKEN_BUDGET_CONCISE=150
TOKEN_BUDGET_DETAILED=250
TOKEN_BUDGET_EXTENSIVE=400

# ── Database (optional) ────────────────────────
DATABASE_URL=

# ── Security Settings (optional) ───────────────
SECRET_KEY=your_super_secret_key_here_change_in_production
